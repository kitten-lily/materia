# Named volume for grimmory MariaDB data files (/var/lib/mysql).
# The minimus mariadb image runs as non-root UID 1000, so the volume is
# created with matching ownership — per the minimus UID-1000 gotcha
# (podman named volumes are root-owned by default). If an existing
# root-owned volume is already present from a prior run, chown on the
# host before restarting: sudo podman unshare chown -R 1000:1000 <path>.
[Volume]
User=1000
Group=1000
