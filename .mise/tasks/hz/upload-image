#!/usr/bin/env bash
#MISE description="Upload Flatcar image to Hetzner as a snapshot (run once; reuse across provisions)"

#USAGE flag "--channel <channel>" help="Flatcar channel" default="stable" {
#USAGE   choices "stable" "beta" "alpha" "lts"
#USAGE }
#USAGE flag "--version <version>" help="Flatcar version" default="current"
#USAGE flag "--arch <arch>" help="Flatcar architecture" default="x86" {
#USAGE   choices "x86" "arm"
#USAGE }
set -euo pipefail

CHANNEL="${usage_channel?}"
VERSION="${usage_version?}"
ARCH="${usage_arch?}"


gum style --foreground 8 "==> uploading Flatcar $CHANNEL/$VERSION to Hetzner (this takes a few minutes)..."

fnox exec -- hcloud-upload-image upload \
  --architecture="${ARCH}" \
  --compression=bz2 \
  --image-url="https://${CHANNEL}.release.flatcar-linux.net/amd64-usr/${VERSION}/flatcar_production_hetzner_image.bin.bz2" \
  --labels "os=flatcar,flatcar-channel=${CHANNEL}" \
  --description "flatcar-${CHANNEL}-${ARCH}"
