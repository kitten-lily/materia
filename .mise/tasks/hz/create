#!/usr/bin/env bash
#MISE description="Create Hetzner server from Flatcar snapshot with Ignition applied at first boot"

#USAGE flag "-v --verbose" help="Print SSH key info and full API responses"
#USAGE flag "--server-name <name>" help="Server name"
#USAGE flag "--server-type <type>" help="Server type (defaults to server.toml's hetzner.type)"
#USAGE flag "--server-location <location>" help="Server location (defaults to server.toml's hetzner.location)"
#USAGE flag "--ign-file <path>" help="Ignition file path (defaults to provisioning/servers/<name>/materia.ign)"

set -euo pipefail

_server_name="${usage_server_name:?server name required, use --server-name}"
_server_toml="provisioning/servers/${_server_name}/server.toml"

if [[ ! -f "$_server_toml" ]]; then
  gum style --foreground 1 "error: $_server_toml not found — run: mise server:new --server-name $_server_name --type hetzner"
  exit 1
fi

_toml_json=$(yq -o=json -p=toml "$_server_toml")
_type=$(echo "$_toml_json" | jq -r '.type // empty')
if [[ "$_type" != "hetzner" ]]; then
  gum style --foreground 1 "error: $_server_toml has type='$_type', not 'hetzner' — use the ipxe/* bare-metal flow instead"
  exit 1
fi

_server_type="${usage_server_type:-$(echo "$_toml_json" | jq -r '.hetzner.type // "cx23"')}"
_server_location="${usage_server_location:-$(echo "$_toml_json" | jq -r '.hetzner.location // "hel1"')}"
_ign_file="${usage_ign_file:-provisioning/servers/${_server_name}/materia.ign}"

_verbose="${usage_verbose:-}"

# Ensures a snapshot exists and isn't too old.
_snap_id=$(mise hz:ensure-image)
[[ -n "$_verbose" ]] && gum style --foreground 8 "==> using Flatcar snapshot id=$_snap_id"

# Build request — Flatcar reads user_data as Ignition directly (no cloud-config wrapper).
# SSH keys are baked into Ignition via passwd.users[].ssh_authorized_keys — Hetzner's
# ssh_keys parameter is ignored when custom user_data is provided.
if [[ ! -f "$_ign_file" ]]; then
  gum style --foreground 1 "error: $_ign_file not found — run: mise ign --server-name $_server_name"
  exit 1
fi

_tmpdir=$(mktemp -d)
trap 'rm -rf "$_tmpdir"' EXIT

gum spin --spinner dot \
  --title "creating server: $_server_name ($_server_type @ $_server_location, snapshot $_snap_id)" \
  -- fnox exec -- hcloud server create --output json \
    --name "$_server_name" \
    --type "$_server_type" \
    --image "$_snap_id" \
    --location "$_server_location" \
    --user-data-from-file "$_ign_file" > "$_tmpdir/resp.json" || true

_resp=$(cat "$_tmpdir/resp.json")
[[ -n "$_verbose" ]] && echo "$_resp" | jq

if echo "$_resp" | jq -e '.error' >/dev/null 2>&1; then
  gum style --foreground 1 "error: Hetzner API rejected:"
  echo "$_resp" | jq
  exit 1
fi

echo "$_resp" | jq '{id: .server.id, name: .server.name,
     ip: .server.public_net.ipv4.ip, status: .server.status}'
gum style --foreground 2 "==> server created — Flatcar boots with Ignition applied directly"
