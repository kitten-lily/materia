#!/usr/bin/env bash
#MISE description="Create Hetzner server from Flatcar snapshot with Ignition applied at first boot"

#USAGE flag "-v --verbose" help="Print SSH key info and full API responses"
#USAGE flag "--server-type <type>" help="Server type" default="cx23"
#USAGE flag "--server-name <name>" help="Server name"
#USAGE flag "--server-location <location>" help="Server location" default="hel1"
#USAGE flag "--ign-file <path>" help="Ignition file path"

set -euo pipefail

_server_type="${usage_server_type:?}"
_server_name="${usage_server_name:-$HCLOUD_SERVER_NAME}"
_server_location="${usage_server_location:?}"
_ign_file="${usage_ign_file:-$IGN_FILE}"

_verbose="${usage_verbose:-}"

# Ensures a snapshot exists and isn't too old.
_snap_id=$(mise hz:ensure-image)
[[ -n "$_verbose" ]] && gum style --foreground 8 "==> using Flatcar snapshot id=$_snap_id"

# Build request — Flatcar reads user_data as Ignition directly (no cloud-config wrapper).
# SSH keys are baked into Ignition via passwd.users[].ssh_authorized_keys — Hetzner's
# ssh_keys parameter is ignored when custom user_data is provided.
if [[ ! -f "$_ign_file" ]]; then
  gum style --foreground 1 "error: $_ign_file not found — run: mise ign"
  exit 1
fi

_tmpdir=$(mktemp -d)
trap 'rm -rf "$_tmpdir"' EXIT

gum spin --spinner dot \
  --title "creating server: $_server_name ($_server_type @ $_server_location, snapshot $_snap_id)" \
  -- fnox exec -- hcloud server create --output json \
    --name "$_server_name" \
    --type "$_server_type" \
    --image "$_snap_id" \
    --location "$_server_location" \
    --user-data-from-file "$_ign_file" > "$_tmpdir/resp.json" || true

_resp=$(cat "$_tmpdir/resp.json")
[[ -n "$_verbose" ]] && echo "$_resp" | jq

if echo "$_resp" | jq -e '.error' >/dev/null 2>&1; then
  gum style --foreground 1 "error: Hetzner API rejected:"
  echo "$_resp" | jq
  exit 1
fi

echo "$_resp" | jq '{id: .server.id, name: .server.name,
     ip: .server.public_net.ipv4.ip, status: .server.status}'
gum style --foreground 2 "==> server created — Flatcar boots with Ignition applied directly"
