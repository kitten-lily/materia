#!/usr/bin/env bash
#MISE description="Ensure a fresh Flatcar snapshot exists on Hetzner; refresh if missing or older than FLATCAR_SNAPSHOT_MAX_AGE_DAYS"
set -euo pipefail
export HCLOUD_TOKEN=$(fnox get HCLOUD_TOKEN)

# All diagnostic output goes to stderr — stdout carries only the resulting snapshot id
# (callers do `_snap_id=$(mise hz:ensure-image)`).

_query() {
  xh --ignore-stdin --check-status --print=b \
    GET "$HCLOUD_API/images?type=snapshot&label_selector=os%3Dflatcar&architecture=x86&sort=created:desc" \
    Authorization:"Bearer $HCLOUD_TOKEN" 2>/dev/null
}

_max_age_days="${FLATCAR_SNAPSHOT_MAX_AGE_DAYS:-30}"

_resp=$(_query)
_id=$(echo "$_resp" | jq -r '.images[0].id // empty')
_created=$(echo "$_resp" | jq -r '.images[0].created // empty')

_stale=0
if [[ -n "$_id" ]]; then
  # GNU date (coreutils) handles Hetzner's "+00:00"-offset ISO8601 timestamps directly.
  _age_days=$(( ( $(date +%s) - $(date -d "$_created" +%s) ) / 86400 ))
  if [[ "$_age_days" -gt "$_max_age_days" ]]; then
    _stale=1
    gum style --foreground 3 "==> Flatcar snapshot id=$_id is ${_age_days}d old (max ${_max_age_days}d) — refreshing" >&2
  fi
else
  gum style --foreground 3 "==> no Flatcar snapshot found — creating one" >&2
fi

if [[ -z "$_id" || "$_stale" -eq 1 ]]; then
  _old_id="$_id"
  mise hz:upload-image >&2
  _id=$(_query | jq -r '.images[0].id // empty')
  if [[ -z "$_id" ]]; then
    gum style --foreground 1 "error: snapshot upload did not produce a queryable image" >&2
    exit 1
  fi
  if [[ -n "$_old_id" && "$_old_id" != "$_id" ]]; then
    gum style --foreground 8 "==> deleting stale snapshot id=$_old_id" >&2
    xh --ignore-stdin --print=b DELETE "$HCLOUD_API/images/$_old_id" \
      Authorization:"Bearer $HCLOUD_TOKEN" >/dev/null 2>&1 || true
  fi
fi

echo "$_id"
