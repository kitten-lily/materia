#!/usr/bin/env bash
#MISE description="Ensure a fresh Flatcar snapshot exists on Hetzner; refresh if missing or older than usage_max_age days"
set -e

#USAGE flag "--arch <architecture>" help="Image architecture" default="x86" {
#USAGE   choices "x86" "arm"
#USAGE }
#USAGE flag "--max-age <days>" help="Maximum age of snapshot in days" default="30"
#USAGE flag "--channel <channel>" help="Flatcar channel" default="stable" {
#USAGE   choices "stable" "beta" "alpha" "lts"
#USAGE }

set -euo pipefail

# All diagnostic output goes to stderr — stdout carries only the resulting snapshot id
# (callers do `_snap_id=$(mise hz:ensure-image)`).

_query() {
    fnox exec -- hcloud image list \
        --type snapshot \
        --selector os=flatcar,flatcar-channel=stable \
        --architecture "${usage_arch?}" \
        --sort created:desc \
        --output json \
        2>/dev/null
}

_max_age_days="${usage_max_age:-30}"

_resp=$(_query)
_id=$(echo "$_resp" | jq -r '.[0].id // empty')
_created=$(echo "$_resp" | jq -r '.[0].created // empty')

_stale=0
if [[ -n "$_id" ]]; then
  # GNU date (coreutils) handles Hetzner's "+00:00"-offset ISO8601 timestamps directly.
  _age_days=$(( ( $(date +%s) - $(date -d "$_created" +%s) ) / 86400 ))
  if [[ "$_age_days" -gt "$_max_age_days" ]]; then
    _stale=1
    gum style --foreground 3 "==> Flatcar snapshot id=$_id is ${_age_days}d old (max ${_max_age_days}d) — refreshing" >&2
  fi
else
  gum style --foreground 3 "==> no Flatcar snapshot found — creating one" >&2
fi

if [[ -z "$_id" || "$_stale" -eq 1 ]]; then
  _old_id="$_id"
  mise hz:upload-image --channel "${usage_channel:?}" >&2
  _id=$(_query | jq -r '.[0].id // empty')
  if [[ -z "$_id" ]]; then
    gum style --foreground 1 "error: snapshot upload did not produce a queryable image" >&2
    exit 1
  fi
  if [[ -n "$_old_id" && "$_old_id" != "$_id" ]]; then
    gum style --foreground 8 "==> deleting stale snapshot id=$_old_id" >&2

    fnox exec -- hcloud image delete "$_old_id" >/dev/null 2>&1 || true
  fi
fi

echo "$_id"
