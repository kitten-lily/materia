#!/usr/bin/env bash
#MISE description="Internal: resolve Hetzner server id+ip by --server-name (hidden helper)"
#MISE hide=true

#USAGE flag "--server-name <name>" help="Server name"
set -euo pipefail

_server_name="${usage_server_name:?server name required, use --server-name}"

_resp=$(fnox exec -- hcloud server describe $_server_name --output json)

printf '%s\t%s\n' \
  "$(echo "$_resp" | jq -r '.id // empty')" \
  "$(echo "$_resp" | jq -r '.public_net.ipv4.ip // empty')"
