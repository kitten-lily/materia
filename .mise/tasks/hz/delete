#!/usr/bin/env bash
#MISE description="Delete Hetzner server by name (requires --confirm)"
#USAGE flag "--confirm" help="Confirm deletion (required)"
#USAGE flag "--noninteractive" help="Exit 1 instead of 0 when --confirm is not passed (for scripting)"
#USAGE flag "--server-name <name>" help="Server name"
set -euo pipefail

_server_name="${usage_server_name:?server name required, use --server-name}"

IFS=$'\t' read -r _id _ip < <(mise hz:_server-id --server-name "$_server_name" 2>/dev/null)

if [[ -z "$_id" ]]; then
  gum style --foreground 8 "==> no server named '$_server_name' — nothing to delete"
  exit 0
fi

if [[ -z "${usage_confirm:-}" ]]; then
  gum style --foreground 3 "==> pass --confirm to delete server: $_server_name"
  [[ -n "${usage_noninteractive:-}" ]] && exit 1
  exit 0
fi

gum style --foreground 8 "==> deleting server: $_server_name (id=$_id, ip=$_ip)"

gum spin --spinner dot --title "deleting $_server_name..." -- \
  fnox exec -- hcloud server delete $_id || true

gum style --foreground 2 "==> deleted: $_server_name (id=$_id)"
