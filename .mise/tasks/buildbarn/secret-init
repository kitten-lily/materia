#!/usr/bin/env bash
#MISE description="Generate the Buildbarn JWT Ed25519 keypair + JWKS and write both to a server's vault (idempotent)"

#USAGE flag "--server-name <name>" help="Server whose vault gets the keypair" default="bow"

set -euo pipefail

_server_name="${usage_server_name:-bow}"
_vault="attributes/${_server_name}.yml"

if [[ ! -f "$_vault" ]]; then
  gum style --foreground 1 "error: $_vault not found — create it first: sops $_vault"
  exit 1
fi

if sops -d "$_vault" 2>/dev/null | yq -e '.components.buildbarn.jwtPrivateKeyPem' >/dev/null 2>&1; then
  gum style --foreground 3 "==> components.buildbarn.jwtPrivateKeyPem already exists in $_vault — skipping."
  gum style --foreground 3 "    Remove it first to regenerate (this invalidates every previously minted token"
  gum style --foreground 3 "    AND requires regenerating the JWKS from the new public key)."
  exit 0
fi

# Ed25519 keypair — Buildbarn's JWT signature validator (go-jose v3 +
# bb-storage/pkg/jwt/configuration.go) only accepts asymmetric public keys
# (ECDSA, Ed25519, RSA). HS256 (symmetric "oct" JWKS key) is rejected at
# TWO layers: go-jose's JSONWebKey.Valid() has no `case []byte:` (returns
# false for oct keys — go-jose issue #314), and even if it passed,
# bb-storage's NewSignatureValidatorFromJSONWebKeySet type switch only
# handles *ecdsa.PublicKey / ed25519.PublicKey / *rsa.PublicKey (no
# []byte/symmetric case). The original HS256 design cannot work with
# buildbarn — switched to EdDSA (Ed25519): single keypair (no CA, no
# per-role client certs), smallest signatures (64 bytes), fastest verify.
# See specs/plans/issue-28-bst-cache-krytis.md.
_tmpdir=$(mktemp -d)
trap 'rm -rf "$_tmpdir"' EXIT

openssl genpkey -algorithm Ed25519 -out "$_tmpdir/priv.pem" 2>/dev/null
openssl pkey -in "$_tmpdir/priv.pem" -pubout -out "$_tmpdir/pub.pem" 2>/dev/null

_priv_pem=$(cat "$_tmpdir/priv.pem")

# JWKS public key: RFC 8037 OKP/Ed25519 JWK. The "x" field is base64url of
# the 32 raw public key bytes. An Ed25519 SPKI DER is a fixed 44-byte
# structure (12-byte ASN.1 header + 32 key bytes), so tail -c 32 reliably
# extracts the raw key. base64url = standard base64 with +/ → -_ and
# padding stripped (RFC 7515 §2).
_pub_b64url=$(openssl pkey -in "$_tmpdir/pub.pem" -pubin -outform DER 2>/dev/null \
  | tail -c 32 | openssl base64 -A | tr '+/' '-_' | tr -d '=')
_jwks=$(jq -cn --arg x "$_pub_b64url" \
  '{keys: [{kty: "OKP", crv: "Ed25519", x: $x, alg: "EdDSA"}]}')

# Write both to the vault via sops --set (jq -Rs JSON-encodes raw bytes,
# avoiding terminal reflow / clipboard corruption of a multi-line PEM —
# same pattern as hz:storagebox:install-key, see BUG-003).
_priv_json=$(jq -Rs . <<<"$_priv_pem")
sops --set "[\"components\"][\"buildbarn\"][\"jwtPrivateKeyPem\"] ${_priv_json}" "$_vault"

_jwks_json=$(jq -Rs . <<<"$_jwks")
sops --set "[\"components\"][\"buildbarn\"][\"jwtJwks\"] ${_jwks_json}" "$_vault"

gum style --foreground 2 "==> Ed25519 keypair + JWKS written to $_vault:"
gum style --foreground 2 "    components.buildbarn.jwtPrivateKeyPem (private key — used by mise buildbarn:mint-token)"
gum style --foreground 2 "    components.buildbarn.jwtJwks        (public key JWKS — mounted into Buildbarn config)"
gum style --foreground 3 "Next: mise buildbarn:mint-token --role push  (and --role pull)"
