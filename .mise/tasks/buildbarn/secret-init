#!/usr/bin/env bash
#MISE description="Generate the Buildbarn JWT HS256 shared secret + JWKS and write both to a server's vault (idempotent)"

#USAGE flag "--server-name <name>" help="Server whose vault gets the secret" default="bow"

set -euo pipefail

_server_name="${usage_server_name:-bow}"
_vault="attributes/${_server_name}.yml"

if [[ ! -f "$_vault" ]]; then
  gum style --foreground 1 "error: $_vault not found — create it first: sops $_vault"
  exit 1
fi

if sops -d "$_vault" 2>/dev/null | yq -e '.components.buildbarn.jwtSecretHex' >/dev/null 2>&1; then
  gum style --foreground 3 "==> components.buildbarn.jwtSecretHex already exists in $_vault — skipping."
  gum style --foreground 3 "    Remove it first to regenerate (this invalidates every previously minted token)."
  exit 0
fi

# Stored as hex, not base64: unambiguous, no padding/charset parsing edge
# cases when re-read for HMAC signing (see mint-token, which feeds it
# straight to `openssl dgst -macopt hexkey:...`).
_secret_hex=$(openssl rand -hex 32)

# JWKS: a single symmetric (oct) key, matching Buildbarn's
# jwt.AuthorizationHeaderParserConfiguration jwks_inline/jwks_file schema.
# The "k" field is base64url of the RAW key bytes (RFC 7518) — not the hex
# string, and not standard base64 — hence the hex-to-raw-to-base64url
# conversion (xxd -r -p decodes hex to raw bytes; tr converts standard
# base64's +/ and strips = padding to get base64url).
_secret_b64url=$(printf '%s' "$_secret_hex" | xxd -r -p | openssl base64 -A | tr '+/' '-_' | tr -d '=')
_jwks=$(jq -cn --arg k "$_secret_b64url" '{keys: [{kty: "oct", k: $k, alg: "HS256"}]}')

_secret_json=$(jq -Rn --arg v "$_secret_hex" '$v')
sops --set "[\"components\"][\"buildbarn\"][\"jwtSecretHex\"] ${_secret_json}" "$_vault"

_jwks_json=$(jq -Rn --arg v "$_jwks" '$v')
sops --set "[\"components\"][\"buildbarn\"][\"jwtJwks\"] ${_jwks_json}" "$_vault"

gum style --foreground 2 "==> secret + JWKS written to $_vault:"
gum style --foreground 2 "    components.buildbarn.jwtSecretHex (used by mise buildbarn:mint-token)"
gum style --foreground 2 "    components.buildbarn.jwtJwks (mounted into Buildbarn's grpcServers.authenticationPolicy.jwt config)"
gum style --foreground 3 "Next: mise buildbarn:mint-token --role push  (and --role pull)"
