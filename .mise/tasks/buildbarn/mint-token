#!/usr/bin/env bash
#MISE description="Mint a Buildbarn push/pull JWT (EdDSA/Ed25519) from the vault-stored private key (prints to stdout, not stored)"

#USAGE flag "--server-name <name>" help="Server whose vault holds the private key" default="bow"
#USAGE flag "--role <role>" help="Token role claim: push or pull"

set -euo pipefail

_server_name="${usage_server_name:-bow}"
_role="${usage_role:?role required, use --role push|pull}"
_vault="attributes/${_server_name}.yml"

case "$_role" in
push | pull) ;;
*)
  gum style --foreground 1 "error: --role must be 'push' or 'pull', got '$_role'"
  exit 1
  ;;
esac

_priv_pem=$(fnox exec -- sops -d "$_vault" 2>/dev/null | yq -r '.components.buildbarn.jwtPrivateKeyPem // ""')
if [[ -z "$_priv_pem" ]]; then
  gum style --foreground 1 "error: components.buildbarn.jwtPrivateKeyPem not found in $_vault"
  gum style --foreground 1 "       run: mise buildbarn:secret-init --server-name $_server_name"
  exit 1
fi

_b64url() { openssl base64 -A | tr '+/' '-_' | tr -d '='; }

# EdDSA (Ed25519) JWT. No "exp" claim — long-lived by design (see
# specs/plans/issue-28-bst-cache-krytis.md). Role differentiation only,
# read server-side via Buildbarn's metadata_extraction_jmespath_expression
# (payload.role) into the putAuthorizer/pushAuthorizer jmespath check.
#
# Signing: Ed25519 is a one-shot signature scheme (not a hash-then-sign
# like RSA/ECDSA), so openssl pkeyutl needs -rawin with the full
# signing_input as the message (no separate -digest). The signature is
# always exactly 64 bytes.
_header=$(printf '%s' '{"alg":"EdDSA","typ":"JWT"}' | _b64url)
_payload_json=$(jq -cn --arg role "$_role" --argjson iat "$(date +%s)" '{role: $role, iat: $iat}')
_payload=$(printf '%s' "$_payload_json" | _b64url)
_signing_input="${_header}.${_payload}"

_tmpdir=$(mktemp -d)
trap 'rm -rf "$_tmpdir"' EXIT

printf '%s' "$_priv_pem" > "$_tmpdir/priv.pem"
printf '%s' "$_signing_input" > "$_tmpdir/input"
openssl pkeyutl -sign -inkey "$_tmpdir/priv.pem" -rawin -in "$_tmpdir/input" -out "$_tmpdir/sig" 2>/dev/null
# base64url the raw 64-byte Ed25519 signature directly — NOT through
# _b64url (which expects text on stdin); `openssl base64 -A -in` reads
# the binary file, then tr converts to base64url and strips padding.
_signature=$(openssl base64 -A -in "$_tmpdir/sig" | tr '+/' '-_' | tr -d '=')
_token="${_signing_input}.${_signature}"

gum style --foreground 2 "==> ${_role} token (not stored anywhere — copy it now):"
echo "$_token"
gum style --foreground 3 ""
if [[ "$_role" == "push" ]]; then
  gum style --foreground 3 "Paste into krytis's GitHub Actions secrets (e.g. BUILDBARN_PUSH_TOKEN)."
else
  gum style --foreground 3 "Distribute out-of-band to any dev machine that needs to fetch (e.g. Proton Pass)."
fi
gum style --foreground 3 "Re-run this task any time to mint another copy — it's derived from the vault key, not independently stored."
